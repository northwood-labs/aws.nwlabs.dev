<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Redirect: {{ original_name }} ({{ stripped_name }})</title>
  </head>
  <body>
    <p>List of supported resources for <a href="https://registry.terraform.io/providers/hashicorp/aws/latest">hashicorp/aws</a> provider v{{ provider_version }}:</p>
    <ol>
    {% for resource in resources %}
      <li><a href="{{ resource.href }}">{{ resource.full_name }}</a></li>
    {% endfor %}
    </ol>
  </body>
</html>
